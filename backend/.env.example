MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=ground_rewards
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
SMS_ENABLED=false
CORS_ORIGINS=http://localhost:3000,http://localhost:3006
REPORT_TIMEZONE=Asia/Manila

# ---- Production hardening (set before deploy) ----
# PRODUCTION=1
#   When set to "1", startup refuses to run with an insecure JWT_SECRET_KEY
#   (empty string or the literal "change-me"). Leave unset for local dev.
#
# ALLOW_INSECURE_JWT=1
#   Opt-out that silences the dev-time warning about insecure JWT secret.
#   Use only in known-trusted local environments.
#
# system_settings.external_api_key (MongoDB)
#   X-API-Key required on /api/external/* (reward-code check/redeem).
#   Seeded as "PLEASE_SET_API_KEY" — calls return 503 until an operator
#   rotates it via the admin Settings UI or directly in the system_settings
#   collection. Rotate before exposing /api/external/* to partners.
